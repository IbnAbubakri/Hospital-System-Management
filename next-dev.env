# Next.js Development Optimizations
# Source this file before running npm run dev
# Run: source next-dev.env && npm run dev

# Disable telemetry (faster startup)
export NEXT_TELEMETRY_DISABLED=1

# Disable ESLint during dev (faster builds)
export ESLINT_NO_DEV=1

# Increase Node.js memory for faster builds (optional)
# export NODE_OPTIONS="--max-old-space-size=4096"
